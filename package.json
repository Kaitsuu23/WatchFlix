{
    "name": "watchflix",
    "version": "1.0.0",
    "description": "WatchFlix - Movie & Series Streaming",
    "main": "dist/index.js",
    "private": true,
    "_moduleAliases": {
        "@": "dist"
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc -w",
        "serve": "concurrently \"npm run watch\" \"nodemon dist/index.js\"",
        "start": "node dist/index.js",
        "prepare": "node -e \"if(process.env.NODE_ENV!=='production'){require('child_process').execSync('husky install',{stdio:'inherit'})}\"",
        "format": "prettier --write ."
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Kaitsuu23/WatchFlix.git"
    },
    "keywords": [
        "watchflix",
        "movies-streaming",
        "web-scraping"
    ],
    "author": "Kaitsuu23",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/Kaitsuu23/WatchFlix/issues"
    },
    "homepage": "https://github.com/Kaitsuu23/WatchFlix#readme",
    "devDependencies": {
        "@commitlint/cli": "^17.4.4",
        "@commitlint/config-conventional": "^17.4.4",
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.17",
        "@types/morgan": "^1.9.4",
        "@types/node": "^18.15.3",
        "@typescript-eslint/eslint-plugin": "^5.55.0",
        "@typescript-eslint/parser": "^5.55.0",
        "eslint": "^8.36.0",
        "eslint-config-prettier": "^8.7.0",
        "eslint-plugin-prettier": "^4.2.1",
        "husky": "^8.0.3",
        "nodemon": "^3.1.14",
        "prettier": "^2.8.4",
        "ts-node": "^10.9.1",
        "typescript": "^4.9.5"
    },
    "dependencies": {
        "@sparticuz/chromium": "^143.0.4",
        "axios": "^1.3.4",
        "cheerio": "^1.0.0-rc.12",
        "concurrently": "^8.2.0",
        "cors": "^2.8.5",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "module-alias": "^2.2.3",
        "morgan": "^1.10.0",
        "puppeteer-core": "^24.39.1"
    }
}
